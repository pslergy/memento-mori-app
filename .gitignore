#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release


# Android local properties (содержит пути к твоему SDK, нельзя шарить)
**/android/local.properties

# SQLite Databases (ВАЖНО: чтобы не слить свои тестовые переписки)
*.db
*.db-wal
*.db-shm

# iOS / MacOS generated files (чтобы репо был чистым для техлидов)
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/ios/Pods/
**/Podfile.lock
.pub-proxy.json

# Secrets & Configs (дополнительная страховка)
secrets.json
config_local.dart

# Backup files
*.bak
*.tmp

# Backend folder Morri (корень репо и внутри lib/)
/Morri/
lib/Morri/

# Astro lib (случайно попал в папку мессенджера, не часть проекта)
/astro_lib/

# Документация: НЕ используйте глобальное *.md — иначе README/LICENSE не попадут в git.
# Проприетарные пути для ПУБЛИЧНОГО зеркала — см. tools/opensource/exclude-from-public.txt
# и scripts/export_public_mirror.* (приватный репозиторий хранит полное дерево).

# Выход экспорта публичного снимка (не коммитить в приватный репо)
/_public_export/
/public_mirror_out/

# Android: ключи и Firebase (не в git)
**/android/key.properties
**/key.properties
**/google-services.json

# --- Mycelium ops: локальные секреты и артефакты (скрипты и примеры — в git) ---
scripts/mycelium_recipe_ops/.venv/
scripts/mycelium_recipe_ops/.env
scripts/mycelium_recipe_ops/*.local.json
scripts/mycelium_recipe_ops/catalog.json
scripts/mycelium_recipe_ops/data/published/